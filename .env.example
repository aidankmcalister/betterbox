# Database (any PostgreSQL connection string)
DATABASE_URL=postgresql://...

# Better Auth
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=...            # also encrypts OAuth tokens at rest

# Google OAuth (Gmail API, gmail.modify scope)
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# Access allowlist: comma-separated emails permitted to create an account.
# Leave empty to allow anyone (handy for local dev). Set it on shared or hosted
# deploys so only listed accounts can get in.
ALLOWED_EMAILS=you@example.com,teammate@example.com

# Optional: enables the Pull requests page
GITHUB_CLIENT_ID=...
GITHUB_CLIENT_SECRET=...

# ─────────────────────────────────────────────
# Self-host mode
# Set to "true" if you are running your own instance.
# Disables the landing page and waitlist — you go
# straight to the app.
# Leave unset on the official hosted deployment.
# ─────────────────────────────────────────────
IS_SELF_HOSTED=true
