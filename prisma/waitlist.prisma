// Hosted-plan waitlist signups live in their own database (WAITLIST_DATABASE_URL),
// kept separate from the app's main DB. Its own schema + generated client so a
// db:push here never touches the app tables and vice versa.
generator client {
  provider = "prisma-client"
  output   = "../src/generated/waitlist"
}

datasource db {
  provider = "postgresql"
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  source    String? // "hero" | "plan" | "final-cta" etc
}
