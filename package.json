{
  "name": "better-mail-2",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.3.9",
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "db:generate": "bun --env-file=.env ./node_modules/.bin/prisma generate",
    "db:push": "bun --env-file=.env ./node_modules/.bin/prisma db push",
    "db:migrate": "bun --env-file=.env ./node_modules/.bin/prisma migrate dev",
    "db:seed": "bun --env-file=.env ./node_modules/.bin/prisma db seed"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-start": "^1.132.0",
    "dotenv": "^17.2.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tanstack/router-plugin": "^1.132.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.4",
    "prisma": "^7.8.0",
    "tsx": "^4.7.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
